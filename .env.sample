# Serveur
APP_PORT=3310

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jasmine_teacher

# Authentification
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=2h

# CORS (URL du front)
CLIENT_URL=http://localhost:5173

# Anti rate-limit pour les tests E2E (ne JAMAIS activer en production).
# DISABLE_RATE_LIMIT=true

# Stripe (mode test) — optionnel : laisser vide pour activer le paiement mock.
# Cle "sk_test_..." disponible sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Signing secret du webhook (genere par : stripe listen --forward-to localhost:3310/api/payments/webhook).
# Sans ce secret, le webhook /api/payments/webhook refusera tous les events (400).
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5173/mon-espace?paid=1
STRIPE_CANCEL_URL=http://localhost:5173/mon-espace?cancelled=1
