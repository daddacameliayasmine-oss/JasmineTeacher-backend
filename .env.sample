# Stripe (mode test) — optionnel : laisser vide pour activer le paiement mock.
# Cle "sk_test_..." disponible sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=http://localhost:5173/mon-espace?paid=1
STRIPE_CANCEL_URL=http://localhost:5173/mon-espace?cancelled=1
